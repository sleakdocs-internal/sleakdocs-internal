{
  "openapi": "3.1.0",
  "info": {
    "title": "Embedding Web",
    "version": "0.1.0"
  },
  "paths": {
    "/process": {
      "post": {
        "summary": "Scrape And Embed Web Pages",
        "description": "Alias of /embedding_web. Scrapes a datasource's web pages and embeds them, dispatching queued pages for v2 datasources or preparing a job from the supplied URLs, then offloading to Hatchet or Cloud Run.",
        "operationId": "scrape_endpoint_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/embedding_web": {
      "post": {
        "summary": "Scrape And Embed Web Pages",
        "description": "Entry point for scraping a datasource's web pages and embedding them. For v2 datasources it dispatches the already-queued scrape_pages; otherwise it prepares a job from the supplied URLs (or the rescrape objects), then offloads to Hatchet or falls back to a Cloud Run job.",
        "operationId": "scrape_endpoint_embedding_web_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/recurring": {
      "post": {
        "summary": "Reconcile And Re-Scrape Datasource",
        "description": "Re-discovers a v2 datasource's live sources and reconciles them against stored pages: detecting added, deleted, and (via sitemap lastmod) changed URLs, purging removed pages and their embeddings, and dispatching a job for the pages that need reprocessing.",
        "operationId": "recurring_endpoint_recurring_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurringRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Recurring Endpoint Recurring Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sitemap/delete": {
      "post": {
        "summary": "Delete Pages For A Source",
        "description": "Deletes all scrape_pages and their Zilliz embeddings that belong to a given source_url within a datasource. Validates that the source_url exists in the datasource_type_config before deleting.",
        "operationId": "sitemap_delete_endpoint_sitemap_delete_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SitemapDeleteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Sitemap Delete Endpoint Sitemap Delete Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sitemap/discover": {
      "post": {
        "summary": "Discover Crawlable Sources",
        "description": "Discovers the sitemaps and crawlable sources for a website URL, optionally applying include/exclude page rules, and returns the grouped sources and URLs without scraping them.",
        "operationId": "sitemap_discover_endpoint_sitemap_discover_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SitemapDiscoverRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SitemapDiscoverResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sitemap/fetch": {
      "post": {
        "summary": "Fetch A Single Sitemap Source",
        "description": "Fetches and parses a single sitemap URL, returning its source entry with the discovered URLs. Returns 422 for invalid sitemap content and 502 when the sitemap cannot be retrieved.",
        "operationId": "sitemap_fetch_endpoint_sitemap_fetch_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SitemapGetRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SitemapGetResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/embedding_web/cloud_run_fallback": {
      "post": {
        "summary": "Dispatch Job To Cloud Run",
        "description": "Force-dispatches an already-prepared job directly to a Cloud Run job, bypassing Hatchet. Used as a fallback when Hatchet offload is unavailable or a queued job needs to be run on Cloud Run.",
        "operationId": "cloud_run_fallback_endpoint_embedding_web_cloud_run_fallback_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CloudRunFallbackRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Cloud Run Fallback Endpoint Embedding Web Cloud Run Fallback Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/debug/hatchet_workers": {
      "get": {
        "summary": "Inspect Hatchet Worker Capacity",
        "description": "Debug endpoint that lists Hatchet workers and reports the active job-serving workers along with their available and total slot counts. Returns hatchet_offload false when offload is disabled.",
        "operationId": "debug_hatchet_workers_debug_hatchet_workers_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CloudRunFallbackRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id",
            "description": "ID of an already-prepared job to (re)dispatch to a Cloud Run job."
          },
          "organization_id": {
            "type": "string",
            "title": "Organization Id",
            "description": "Organization that owns the job; passed into the Cloud Run job env."
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "organization_id"
        ],
        "title": "CloudRunFallbackRequest"
      },
      "DiscoverPathGroup": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "urls": {
            "items": {
              "$ref": "#/components/schemas/DiscoverUrlEntry"
            },
            "type": "array",
            "title": "Urls"
          }
        },
        "type": "object",
        "required": [
          "path",
          "count",
          "urls"
        ],
        "title": "DiscoverPathGroup"
      },
      "DiscoverRules": {
        "properties": {
          "include": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Include",
            "default": []
          },
          "exclude": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Exclude",
            "default": []
          }
        },
        "type": "object",
        "title": "DiscoverRules"
      },
      "DiscoverSource": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type"
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          },
          "has_lastmod": {
            "type": "boolean",
            "title": "Has Lastmod"
          },
          "paths": {
            "items": {
              "$ref": "#/components/schemas/DiscoverPathGroup"
            },
            "type": "array",
            "title": "Paths"
          }
        },
        "type": "object",
        "required": [
          "type",
          "has_lastmod",
          "paths"
        ],
        "title": "DiscoverSource"
      },
      "DiscoverUrlEntry": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "lastmod": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lastmod"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "DiscoverUrlEntry"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RecurringRequest": {
        "properties": {
          "datasource_id": {
            "type": "string",
            "title": "Datasource Id",
            "description": "ID of the v2 data_source to reconcile against its live sources."
          }
        },
        "type": "object",
        "required": [
          "datasource_id"
        ],
        "title": "RecurringRequest"
      },
      "ScrapeRequest": {
        "properties": {
          "urls": {
            "anyOf": [
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Urls",
            "description": "URLs to scrape. For a fresh scrape this is a list of URL strings; when rescrape is true each item is an object carrying both 'url' and the existing 'id' of the scrape_pages row to update. Ignored for v2 datasources, which pull queued pages from the database instead."
          },
          "datasource_id": {
            "type": "string",
            "title": "Datasource Id",
            "description": "ID of the data_source these URLs belong to."
          },
          "organization_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Organization Id",
            "description": "Organization that owns the job; if omitted it is inferred from the queued scrape_pages rows (v2)."
          },
          "chatbot_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chatbot Id",
            "description": "Chatbot the scraped content is associated with; if omitted it is inferred from the queued scrape_pages rows (v2)."
          },
          "rescrape": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rescrape",
            "description": "When true, treat each urls item as an existing page object ({'url', 'id'}) and re-scrape it in place rather than creating new pages.",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "datasource_id"
        ],
        "title": "ScrapeRequest"
      },
      "ScrapeResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "description": "Whether the scrape job was accepted and dispatched."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable summary of what was dispatched or why it was not."
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error",
            "description": "Error detail when the request could not be processed."
          },
          "job_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Id",
            "description": "Identifier of the created job, used to track processing progress."
          }
        },
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "title": "ScrapeResponse"
      },
      "SitemapDeleteRequest": {
        "properties": {
          "datasource_id": {
            "type": "string",
            "title": "Datasource Id",
            "description": "ID of the data_source whose pages should be removed."
          },
          "source_url": {
            "type": "string",
            "title": "Source Url",
            "description": "The source_url (sitemap/crawl source) whose pages and embeddings should be deleted; must exist in the datasource_type_config sources list."
          }
        },
        "type": "object",
        "required": [
          "datasource_id",
          "source_url"
        ],
        "title": "SitemapDeleteRequest"
      },
      "SitemapDiscoverRequest": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "chatbot_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chatbot Id"
          },
          "page_rules": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DiscoverRules"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "SitemapDiscoverRequest"
      },
      "SitemapDiscoverResponse": {
        "properties": {
          "website_url": {
            "type": "string",
            "title": "Website Url"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/DiscoverSource"
            },
            "type": "array",
            "title": "Sources"
          },
          "page_rules": {
            "$ref": "#/components/schemas/DiscoverRules",
            "default": {
              "include": [],
              "exclude": []
            }
          }
        },
        "type": "object",
        "required": [
          "website_url",
          "sources"
        ],
        "title": "SitemapDiscoverResponse"
      },
      "SitemapGetRequest": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "SitemapGetRequest"
      },
      "SitemapGetResponse": {
        "properties": {
          "source": {
            "$ref": "#/components/schemas/DiscoverSource"
          }
        },
        "type": "object",
        "required": [
          "source"
        ],
        "title": "SitemapGetResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}