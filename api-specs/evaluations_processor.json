{
  "openapi": "3.1.0",
  "info": {
    "title": "Evaluations Processor",
    "description": "A FastAPI application for processing chat evaluations",
    "version": "1.0"
  },
  "paths": {
    "/process": {
      "post": {
        "summary": "Process Chat Evaluation",
        "description": "Runs LangSmith trace and thread evaluations for a chat and pushes the results to Grafana.",
        "operationId": "process_evaluation_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EvaluationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/process_qa": {
      "post": {
        "summary": "Process QA Evaluation",
        "description": "Queues a background QA evaluation for a single bot message, using the chat_id and message id from the provided record.",
        "operationId": "process_qa_evaluation_process_qa_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QAEvaluationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EvaluationRequest": {
        "properties": {
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Unique identifier for the chat to evaluate."
          }
        },
        "type": "object",
        "required": [
          "chat_id"
        ],
        "title": "EvaluationRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Liveness status of the service."
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "QAEvaluationRequest": {
        "properties": {
          "record": {
            "$ref": "#/components/schemas/QARecord",
            "description": "Record containing the chat_id and bot message id to evaluate."
          }
        },
        "additionalProperties": true,
        "type": "object",
        "title": "QAEvaluationRequest"
      },
      "QARecord": {
        "properties": {
          "chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chat Id",
            "description": "Identifier of the chat the QA pair belongs to."
          },
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id",
            "description": "Identifier of the bot message being evaluated."
          }
        },
        "additionalProperties": true,
        "type": "object",
        "title": "QARecord"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}