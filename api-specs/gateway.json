  "paths": {
    "/embedding_xml_processor": {
      "post": {
        "summary": "Process XML Sitemap Embeddings",
        "description": "Forwards the raw JSON body to the XML embedding processor, running it via the sleak-embedding-xml Hatchet workflow and falling back to the embedding-xml Cloud Run service. See the Embedding XML Processor service for the request body schema.",
        "operationId": "embedding_xml_processor_embedding_xml_processor_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/embedding_web": {
      "post": {
        "summary": "Queue Web Page Embedding",
        "description": "Forwards the raw JSON body to the web embedding queue, running it via the sleak-embedding-web-queue Hatchet workflow and falling back to the embedding-web-queue Cloud Run service. See the Embedding Web service for the request body schema.",
        "operationId": "embedding_web_embedding_web_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/queueing_evaluations": {
      "post": {
        "summary": "Queue Evaluations",
        "description": "Forwards the raw JSON body to the evaluation queueing service, running it via the sleak-queue-evaluation Hatchet workflow and falling back to the queue-evaluation Cloud Run service. See the Queueing Evaluations service for the request body schema.",
        "operationId": "queueing_evaluations_queueing_evaluations_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/evaluations_processor": {
      "post": {
        "summary": "Process Evaluations",
        "description": "Forwards the raw JSON body to the evaluations processor, running it via the sleak-process-evaluation Hatchet workflow and falling back to the process-evaluation Cloud Run service. See the Evaluations Processor service for the request body schema.",
        "operationId": "evaluations_processor_evaluations_processor_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/agent": {
      "post": {
        "summary": "Process Agent Message",
        "description": "Forwards the raw JSON body to the Agent service, running it via the sleak-agent-process-message Hatchet workflow (tagging chat_id, chatbot_id and organization_id as metadata) and falling back to the agent Cloud Run service at /webhook/message. See the Agent service for the request body schema.",
        "operationId": "agent_agent_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/embedding/csv": {
      "post": {
        "summary": "Embed CSV File",
        "description": "Accepts a multipart CSV upload plus datasource, organization and chatbot identifiers, then embeds it via the sleak-embedding-csv Hatchet workflow (base64-encoding the file) and falls back to the embedding-csv Cloud Run service on failure.",
        "operationId": "embedding_csv_embedding_csv_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_embedding_csv_embedding_csv_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/embedding/pdf": {
      "post": {
        "summary": "Embed PDF File",
        "description": "Accepts a multipart PDF upload plus datasource, organization and chatbot identifiers, then embeds it via the sleak-embedding-pdf Hatchet workflow (base64-encoding the file) and falls back to the embedding-pdf Cloud Run service on failure.",
        "operationId": "embedding_pdf_embedding_pdf_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_embedding_pdf_embedding_pdf_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root Liveness Probe",
        "description": "Returns a plain \"OK\" string confirming the gateway is running.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
