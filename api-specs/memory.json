{
  "openapi": "3.1.0",
  "info": {
    "title": "Memory Service",
    "description": "A service for managing conversation memory using PostgreSQL checkpointing",
    "version": "1.0"
  },
  "paths": {
    "/add-messages": {
      "post": {
        "summary": "Append Messages To Session Memory",
        "description": "Appends the provided messages to a session's PostgreSQL-checkpointed conversation history, deduplicating any messages whose id already exists in the session and sorting new messages by their timestamp before persisting.",
        "operationId": "append_memory_add_messages_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppendMemoryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppendMemoryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppendMemoryRequest": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id",
            "description": "Conversation thread identifier used as the checkpointer thread_id to scope stored messages"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/MessageObject"
            },
            "type": "array",
            "title": "Messages",
            "description": "Array of message objects with role and content"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "messages"
        ],
        "title": "AppendMemoryRequest"
      },
      "AppendMemoryResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Outcome of the append operation; 'success' when the request was processed"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id",
            "description": "Conversation thread identifier the messages were appended to"
          },
          "messages_appended": {
            "type": "integer",
            "title": "Messages Appended",
            "description": "Number of messages received in the request payload, before deduplication"
          },
          "messages_ingested": {
            "type": "integer",
            "title": "Messages Ingested",
            "description": "Number of new messages actually persisted after removing duplicates by id",
            "default": 0
          },
          "total_messages": {
            "type": "integer",
            "title": "Total Messages",
            "description": "Total number of messages stored in the session after this operation"
          }
        },
        "type": "object",
        "required": [
          "status",
          "session_id",
          "messages_appended",
          "total_messages"
        ],
        "title": "AppendMemoryResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MessageObject": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role",
            "description": "Role of the message: 'human', 'ai', or 'system'"
          },
          "content": {
            "type": "string",
            "title": "Content",
            "description": "Content of the message",
            "default": ""
          },
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id",
            "description": "Optional message ID for deduplication"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp",
            "description": "Optional Unix timestamp of the message"
          }
        },
        "type": "object",
        "required": [
          "role"
        ],
        "title": "MessageObject"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}