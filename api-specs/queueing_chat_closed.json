{
  "openapi": "3.1.0",
  "info": {
    "title": "Chat Queue",
    "description": "A FastAPI application for managing chat queues with configurable timeout",
    "version": "1.0"
  },
  "paths": {
    "/queueing/close_chat": {
      "post": {
        "summary": "Close Or Delete Chat",
        "description": "Deletes the chat when 'delete' is true, otherwise schedules a delayed Cloud Tasks job to close it.",
        "operationId": "queue_or_delete_chat_queueing_close_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CloseChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/ChatResponse"
                    },
                    {
                      "$ref": "#/components/schemas/DeleteResponse"
                    }
                  ],
                  "title": "Response Queue Or Delete Chat Queueing Close Chat Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Outcome of scheduling the close task."
          },
          "task_id": {
            "type": "string",
            "title": "Task Id",
            "description": "Identifier of the scheduled Cloud Tasks job."
          },
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Echoed identifier of the chat."
          }
        },
        "type": "object",
        "required": [
          "status",
          "task_id",
          "chat_id"
        ],
        "title": "ChatResponse"
      },
      "CloseChatRequest": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Identifier of the chat to close or delete."
          },
          "delete": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Delete",
            "description": "If true, delete the chat instead of scheduling a close task."
          },
          "visitor_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Visitor Id",
            "description": "Identifier of the visitor associated with the chat."
          },
          "chatbot_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chatbot Id",
            "description": "Identifier of the chatbot handling the chat."
          },
          "organization_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Organization Id",
            "description": "Identifier of the owning organization."
          },
          "chat_closing_settings": {
            "additionalProperties": true,
            "type": "object",
            "title": "Chat Closing Settings",
            "description": "Settings controlling chat-closing behavior."
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "id"
        ],
        "title": "CloseChatRequest"
      },
      "DeleteResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Outcome of the delete operation."
          },
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Echoed identifier of the chat."
          },
          "deleted_count": {
            "type": "integer",
            "title": "Deleted Count",
            "description": "Number of records deleted for the chat.",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "status",
          "chat_id"
        ],
        "title": "DeleteResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Liveness status of the service."
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}