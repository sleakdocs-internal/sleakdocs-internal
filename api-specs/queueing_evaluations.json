{
  "openapi": "3.1.0",
  "info": {
    "title": "Chat Evaluation Queue",
    "description": "A FastAPI application for managing chat evaluation queues with 15-minute timeout",
    "version": "1.0"
  },
  "paths": {
    "/queueing/evaluations": {
      "post": {
        "summary": "Queue Chat Evaluation",
        "description": "Schedules a delayed Cloud Tasks job that triggers the n8n evaluation webhook for a chat. Skips queueing when the chatbot's daily rate limit is reached, the chat is already evaluated, the chat has no llm_model, or the chat has 5 or fewer messages; any existing task for the same chat is replaced.",
        "operationId": "queue_chat_evaluation_queueing_evaluations_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EvaluationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EvaluationResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EvaluationRequest": {
        "properties": {
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Unique identifier for the chat"
          },
          "visitor_id": {
            "type": "string",
            "title": "Visitor Id",
            "description": "Unique identifier for the visitor"
          },
          "chatbot_id": {
            "type": "string",
            "title": "Chatbot Id",
            "description": "Unique identifier for the chatbot"
          }
        },
        "type": "object",
        "required": [
          "chat_id",
          "visitor_id",
          "chatbot_id"
        ],
        "title": "EvaluationRequest"
      },
      "EvaluationResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Outcome of the queueing request: 'success' when a task was created, or 'skipped' when the chat was rate-limited, already evaluated, missing an llm_model, or had 5 or fewer messages"
          },
          "task_id": {
            "type": "string",
            "title": "Task Id",
            "description": "Full Cloud Tasks resource name of the created evaluation task, or an empty string when the request was skipped"
          },
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Identifier of the chat this response refers to, echoed back from the request"
          }
        },
        "type": "object",
        "required": [
          "status",
          "task_id",
          "chat_id"
        ],
        "title": "EvaluationResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Service health indicator, always 'healthy' when the endpoint responds"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}