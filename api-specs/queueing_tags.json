{
  "openapi": "3.1.0",
  "info": {
    "title": "Chat Queue",
    "description": "A FastAPI application for managing chat queues with 15-minute timeout",
    "version": "1.0"
  },
  "paths": {
    "/queueing/tags": {
      "post": {
        "summary": "Queue Chat Tagging Task",
        "description": "Schedules a Cloud Tasks job that calls the n8n webhook to tag the chat 15 minutes later. Any pending task previously queued for the same chat is deleted first, so the timer effectively resets on every call.",
        "operationId": "queue_chat_tag_queueing_tags_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Unique identifier for the chat"
          },
          "visitor_id": {
            "type": "string",
            "title": "Visitor Id",
            "description": "Unique identifier for the visitor"
          },
          "chatbot_id": {
            "type": "string",
            "title": "Chatbot Id",
            "description": "Chatbot id for the chat"
          }
        },
        "type": "object",
        "required": [
          "chat_id",
          "visitor_id",
          "chatbot_id"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Outcome of the queueing operation; 'success' when the task was created"
          },
          "task_id": {
            "type": "string",
            "title": "Task Id",
            "description": "Fully qualified Cloud Tasks resource name of the created task"
          },
          "chat_id": {
            "type": "string",
            "title": "Chat Id",
            "description": "Identifier of the chat the queued task belongs to"
          }
        },
        "type": "object",
        "required": [
          "status",
          "task_id",
          "chat_id"
        ],
        "title": "ChatResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Service health indicator; 'healthy' when the API is up"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}