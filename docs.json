{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Sleak internal docs",
  "custom_css": ["/custom.css"],
  "seo": {
    "indexing": "navigable"
  },
  "colors": {
    "primary": "#8551FB",
    "light": "#A78BFA",
    "dark": "#6B3BDB"
  },
  "favicon": "/logo/sleakfavicon.png",
  "navigation": {
    "pages": [
      {
        "group": "Internal",
        "pages": ["index"]
      },
      {
        "group": "API Reference",
        "pages": ["api-reference/introduction"]
      },
      {
        "group": "Agent",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /agent/webhook/message"]
      },
      {
        "group": "Memory Service",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /memory/add-messages"]
      },
      {
        "group": "Embedding Web",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": [
          "POST /embedding_web/process",
          "POST /embedding_web/recurring",
          "POST /embedding_web/sitemap/delete",
          "POST /embedding_web/sitemap/discover",
          "POST /embedding_web/sitemap/fetch",
          "POST /embedding_web/embedding_web/cloud_run_fallback",
          "GET /embedding_web/debug/hatchet_workers"
        ]
      },
      {
        "group": "Evaluations Processor",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /evaluations_processor/process", "POST /evaluations_processor/process_qa"]
      },
      {
        "group": "Chat Evaluation Queue",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /queueing_evaluations/queueing/evaluations"]
      },
      {
        "group": "Chat Closing Queue",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /queueing_chat_closed/queueing/close_chat"]
      },
      {
        "group": "Chat Tagging Queue",
        "expanded": true,
        "openapi": "openapi.json",
        "pages": ["POST /queueing_tags/queueing/tags"]
      }
    ]
  },
  "logo": {
    "light": "/logo/sleaklogo_full_darktext_padding.png",
    "dark": "/logo/sleaklogo_full_lighttext_padding.png"
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "source": "https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/Geist-SemiBold.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "source": "https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "search": {
    "location": "top"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "navbar": {
    "links": [
      {
        "label": "Public API reference",
        "href": "https://docs.sleak.chat/api/overview"
      },
      {
        "label": "Public Docs",
        "href": "https://docs.sleak.chat"
      }
    ]
  },
  "footer": {},
  "icons": {
    "library": "lucide"
  }
}
