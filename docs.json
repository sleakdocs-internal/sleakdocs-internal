{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sleak",
  "custom_css": ["/custom.css"],
  "colors": {
    "primary": "#8551FB",
    "light": "#A78BFA",
    "dark": "#6B3BDB"
  },
  "favicon": "/logo/sleakfavicon.png",
  "navigation": {
    "pages": [
      {
        "group": "Internal",
        "public": true,
        "pages": ["index"]
      },
      {
        "group": "API Reference",
        "public": true,
        "pages": [
          "api-reference/introduction",
          "api-reference/ping"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/sleaklogo_full_darktext_padding.png",
    "dark": "/logo/sleaklogo_full_lighttext_padding.png"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://sleak.chat"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.sleak.chat"
    }
  },
  "footer": {
    "socials": {
      "website": "https://sleak.chat",
      "linkedin": "https://www.linkedin.com/company/sleak-chat"
    }
  }
}
