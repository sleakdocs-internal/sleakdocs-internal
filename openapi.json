{
  "openapi": "3.0.0",
  "info": {
    "title": "Sleak Internal API",
    "version": "1.0.0",
    "description": "Internal API for Sleak services"
  },
  "servers": [
    {
      "url": "https://api.v1.sleak.chat"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "summary": "Ping",
        "description": "Check if the API is alive",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "pong"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
